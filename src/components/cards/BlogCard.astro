---
interface Props {
  title: string;
  summary: string;
  topic: string;
  publishedAt: Date;
  tags: string[];
  slug: string;
}
const { title, summary, topic, publishedAt, tags, slug } = Astro.props;
const formattedDate = publishedAt.toLocaleDateString('en-US', {
  day: 'numeric',
  month: 'short',
  year: 'numeric'
});
---
<article class="card-surface h-full p-6">
  <div class="flex flex-wrap items-center gap-3 text-xs uppercase tracking-[0.25em] text-slate-400">
    <span>Blog</span>
    <span>•</span>
    <time datetime={publishedAt.toISOString()}>{formattedDate}</time>
  </div>
  <div class="mt-4 flex flex-wrap gap-2">
    <span class="rounded-full border border-brand-300/30 bg-brand-400/10 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.2em] text-brand-100">{topic}</span>
  </div>
  <h3 class="mt-4 text-2xl font-semibold text-white">{title}</h3>
  <p class="mt-3 text-sm leading-7 text-slate-300">{summary}</p>
  <div class="mt-5 flex flex-wrap gap-2">
    {tags.map((tag) => <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-slate-200">{tag}</span>)}
  </div>
  <a href={`/blog/${slug}`} class="mt-6 inline-flex text-sm font-semibold text-brand-200">Read article →</a>
</article>
