---
interface Props {
  title: string;
  summary: string;
  topic: string;
  format: string;
  level: string;
  slug: string;
  downloadUrl?: string;
  ctaLabel?: string;
}
const { title, summary, topic, format, level, slug, downloadUrl, ctaLabel = 'View resource' } = Astro.props;
---
<article class="card-surface h-full p-6">
  <div class="flex flex-wrap gap-2 text-xs uppercase tracking-[0.2em] text-slate-400">
    <span>{topic}</span>
    <span>•</span>
    <span>{format}</span>
    <span>•</span>
    <span>{level}</span>
  </div>
  <h3 class="mt-4 text-xl font-semibold text-white">{title}</h3>
  <p class="mt-3 text-sm leading-7 text-slate-300">{summary}</p>
  <div class="mt-6 flex flex-wrap gap-3">
    <a href={`/resources/${slug}`} class="rounded-full bg-brand-500 px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-400">Read overview</a>
    {downloadUrl && <a href={downloadUrl} download class="rounded-full border border-white/15 px-4 py-2 text-sm font-semibold text-slate-100 transition hover:border-white/30 hover:bg-white/5">{ctaLabel}</a>}
  </div>
</article>
