---
interface Props {
  title: string;
  href: string;
  summary: string;
  subtopics: string[];
}
const { title, href, summary, subtopics } = Astro.props;
---
<a href={href} class="card-surface group block h-full p-6 transition hover:-translate-y-1 hover:border-brand-400/40 hover:bg-white/10">
  <p class="text-sm font-semibold uppercase tracking-[0.25em] text-brand-200">Expertise</p>
  <h3 class="mt-4 text-2xl font-semibold text-white">{title}</h3>
  <p class="mt-3 text-sm leading-7 text-slate-300">{summary}</p>
  <ul class="mt-6 space-y-2 text-sm text-slate-200">
    {subtopics.slice(0, 3).map((item) => <li>• {item}</li>)}
  </ul>
  <span class="mt-6 inline-flex text-sm font-semibold text-brand-200">Explore topic →</span>
</a>
