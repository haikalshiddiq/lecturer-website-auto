---
import { siteConfig } from '../../data/site';
---
<footer class="border-t border-white/10 py-12">
  <div class="container-shell grid gap-8 md:grid-cols-[1.2fr_0.8fr]">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-brand-200">Lecturer Website</p>
      <h2 class="mt-4 text-2xl font-semibold text-white">A responsive, Cloudflare-ready academic platform.</h2>
      <p class="mt-3 max-w-2xl text-sm leading-7 text-slate-300">Built for premium presentation, scalable learning content, and reliable long-term maintenance through GitHub and Cloudflare automation.</p>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <p class="text-sm font-semibold text-white">Navigation</p>
        <ul class="mt-3 space-y-2 text-sm text-slate-300">
          {siteConfig.navigation.map((item) => <li><a class="hover:text-white" href={item.href}>{item.label}</a></li>)}
        </ul>
      </div>
      <div>
        <p class="text-sm font-semibold text-white">Connect</p>
        <ul class="mt-3 space-y-2 text-sm text-slate-300">
          {siteConfig.socialLinks.map((item) => <li><a class="hover:text-white" href={item.href} target="_blank" rel="noreferrer">{item.label}</a></li>)}
        </ul>
      </div>
    </div>
  </div>
</footer>
