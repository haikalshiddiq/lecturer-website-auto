---
interface Props {
  title: string;
  description: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref: string;
  secondaryLabel: string;
}
const { title, description, primaryHref, primaryLabel, secondaryHref, secondaryLabel } = Astro.props;
---
<section class="py-20">
  <div class="container-shell">
    <div class="card-surface overflow-hidden p-8 sm:p-10 lg:p-12">
      <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.28em] text-brand-200">Work with Haikal Shiddiq</p>
          <h2 class="mt-4 text-3xl font-semibold text-white sm:text-4xl">{title}</h2>
          <p class="mt-4 max-w-2xl text-base leading-7 text-slate-300">{description}</p>
        </div>
        <div class="flex flex-wrap gap-4 lg:justify-end">
          <a href={primaryHref} class="rounded-full bg-brand-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-brand-400">{primaryLabel}</a>
          <a href={secondaryHref} class="rounded-full border border-white/15 px-6 py-3 text-sm font-semibold text-slate-100 transition hover:border-white/30 hover:bg-white/5">{secondaryLabel}</a>
        </div>
      </div>
    </div>
  </div>
</section>
