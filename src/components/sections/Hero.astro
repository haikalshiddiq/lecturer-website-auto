---
import { profile } from '../../data/profile';
import ActionLink from '../ui/ActionLink.astro';
import GradientPanel from '../ui/GradientPanel.astro';
import Pill from '../ui/Pill.astro';
---
<section class="relative overflow-hidden py-20 sm:py-24">
  <div class="absolute inset-x-0 top-0 -z-10 h-[32rem] bg-[radial-gradient(circle_at_top_left,_rgba(168,85,247,0.34),_transparent_35%),radial-gradient(circle_at_top_right,_rgba(34,211,238,0.22),_transparent_30%),radial-gradient(circle_at_bottom,_rgba(250,204,21,0.16),_transparent_26%)]"></div>
  <div class="container-shell grid items-center gap-10 lg:grid-cols-[1.05fr_0.95fr]">
    <div>
      <div class="flex flex-wrap gap-3">
        <Pill tone="fuchsia">Wayground-inspired learning experience</Pill>
        <Pill tone="cyan">Interactive lecturer platform</Pill>
      </div>
      <h1 class="mt-8 max-w-4xl text-5xl font-semibold tracking-tight text-white sm:text-6xl lg:text-7xl">
        Turn every visit into a guided learning journey.
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">
        {profile.shortBio}
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <ActionLink href="#topic-studio">Explore topic studio</ActionLink>
        <ActionLink href="#resource-explorer" variant="secondary">Browse resource explorer</ActionLink>
      </div>
      <div class="mt-10 grid gap-4 sm:grid-cols-3">
        <div class="rounded-3xl border border-white/10 bg-white/8 p-5 backdrop-blur">
          <p class="text-xs uppercase tracking-[0.28em] text-fuchsia-200">Track 01</p>
          <p class="mt-2 text-lg font-semibold text-white">Information System Management</p>
          <p class="mt-2 text-sm text-slate-300">Strategy, governance, and measurable digital transformation.</p>
        </div>
        <div class="rounded-3xl border border-white/10 bg-white/8 p-5 backdrop-blur">
          <p class="text-xs uppercase tracking-[0.28em] text-cyan-200">Track 02</p>
          <p class="mt-2 text-lg font-semibold text-white">Communication Protocol</p>
          <p class="mt-2 text-sm text-slate-300">Observable protocol logic, packet thinking, and troubleshooting discipline.</p>
        </div>
        <div class="rounded-3xl border border-white/10 bg-white/8 p-5 backdrop-blur">
          <p class="text-xs uppercase tracking-[0.28em] text-amber-200">Track 03</p>
          <p class="mt-2 text-lg font-semibold text-white">Artificial Intelligence</p>
          <p class="mt-2 text-sm text-slate-300">Responsible adoption, prompt design, and practical academic workflows.</p>
        </div>
      </div>
    </div>

    <div class="relative">
      <div class="absolute -left-8 top-8 h-24 w-24 rounded-full bg-fuchsia-500/25 blur-3xl"></div>
      <div class="absolute -right-8 bottom-8 h-24 w-24 rounded-full bg-cyan-400/25 blur-3xl"></div>
      <GradientPanel class="relative overflow-hidden p-6 sm:p-8">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(255,255,255,0.12),_transparent_52%)]"></div>
        <div class="relative space-y-5">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.3em] text-brand-200">Learning pulse</p>
              <p class="mt-2 text-2xl font-semibold text-white">Playful, guided, and content-rich</p>
            </div>
            <div class="rounded-2xl border border-emerald-400/20 bg-emerald-400/10 px-4 py-2 text-sm font-medium text-emerald-200">Daily maintained</div>
          </div>
          <div class="grid gap-4">
            <div class="rounded-[1.75rem] border border-white/10 bg-slate-900/70 p-5">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-sm font-semibold text-white">Explore</p>
                  <p class="mt-2 text-sm text-slate-300">Switch between subject pillars and inspect the learning outcomes instantly.</p>
                </div>
                <span class="rounded-full bg-fuchsia-500 px-3 py-1 text-xs font-semibold text-white">Interactive tabs</span>
              </div>
              <div class="mt-4 h-2 overflow-hidden rounded-full bg-white/10">
                <div class="h-full w-[88%] rounded-full bg-gradient-to-r from-fuchsia-500 via-violet-500 to-cyan-400"></div>
              </div>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              <div class="rounded-[1.75rem] border border-white/10 bg-white/5 p-5">
                <p class="text-sm font-semibold text-white">Practice</p>
                <p class="mt-2 text-sm text-slate-300">Filter resources, open learning notes, and download class-ready materials.</p>
              </div>
              <div class="rounded-[1.75rem] border border-white/10 bg-white/5 p-5">
                <p class="text-sm font-semibold text-white">Apply</p>
                <p class="mt-2 text-sm text-slate-300">Use blog insights and project highlights as real classroom conversation starters.</p>
              </div>
            </div>
            <div class="rounded-[1.75rem] border border-white/10 bg-gradient-to-r from-violet-500/15 via-fuchsia-500/10 to-cyan-500/15 p-5">
              <div class="flex flex-wrap gap-3 text-xs uppercase tracking-[0.25em] text-slate-200">
                <span class="rounded-full border border-white/10 px-3 py-2">Gamified energy</span>
                <span class="rounded-full border border-white/10 px-3 py-2">Academic credibility</span>
                <span class="rounded-full border border-white/10 px-3 py-2">Fast edge delivery</span>
              </div>
            </div>
          </div>
        </div>
      </GradientPanel>
    </div>
  </div>
</section>
