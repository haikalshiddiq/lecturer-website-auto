---
type Lab = {
  slug: string;
  kitSlug: string;
  runtimeId: 'ism' | 'protocol' | 'ai';
  eyebrow: string;
  title: string;
  duration: string;
  scenario: string;
  outcomes: string[];
  stations: { title: string; time: string; mission: string; steps: string[]; evidence: string }[];
  toolkit: { label: string; detail: string }[];
  dataset: { title: string; rows: string[][]; headers: string[] };
  commands: { label: string; code: string }[];
  quiz: { q: string; options: string[]; answer: string; explain: string }[];
  rubric: { criterion: string; excellent: string; points: string }[];
  deliverables: string[];
};

const labs: Record<string, Lab> = {
  'youcom-hands-on-lab-ism-incident-dashboard': {
    slug: 'youcom-hands-on-lab-ism-incident-dashboard',
    kitSlug: 'ism-incident-dashboard',
    runtimeId: 'ism',
    eyebrow: 'Information System Management Interactive Lab',
    title: 'AI Incident Intelligence Dashboard Studio',
    duration: '120–150 minutes',
    scenario: 'Students act as a crisis analytics cell for a national digital-service outage. They convert fragmented reports, event logs, source credibility scores, and recovery decisions into a management-ready incident intelligence dashboard.',
    outcomes: [
      'Separate operational facts, uncertain claims, and executive assumptions during an incident.',
      'Map incident evidence to service impact, ownership, risk, and response priority.',
      'Design dashboard widgets that support management decisions rather than visual decoration.',
      'Apply AI-assisted summarisation with traceability, source scoring, and human approval gates.'
    ],
    stations: [
      {
        title: '1. Crisis intake and source triage',
        time: '25 min',
        mission: 'Build the first evidence register from noisy public and internal claims.',
        steps: [
          'Classify each claim as confirmed, likely, disputed, or unknown.',
          'Assign source type: government, vendor, media, social, internal operations, or academic.',
          'Score credibility from 1–5 using authority, recency, specificity, and corroboration.',
          'Write one AI prompt that asks for a summary but forces citation of claim IDs.'
        ],
        evidence: 'Evidence register with at least 10 claims, credibility score, and decision status.'
      },
      {
        title: '2. Service impact model',
        time: '30 min',
        mission: 'Translate technical symptoms into affected service, citizen/business impact, and owner accountability.',
        steps: [
          'Create a service map: service, users, data sensitivity, owner, dependencies.',
          'Estimate impact severity using population affected, legal exposure, and recovery complexity.',
          'Mark dashboard KPIs that an executive should see every 15 minutes.',
          'Identify which KPI could be misleading without context.'
        ],
        evidence: 'Impact matrix and dashboard KPI rationale.'
      },
      {
        title: '3. AI-assisted timeline reconstruction',
        time: '35 min',
        mission: 'Use event fragments to reconstruct a defensible incident timeline.',
        steps: [
          'Normalize all timestamps and identify missing intervals.',
          'Group events by detection, containment, eradication, recovery, and communication.',
          'Add confidence labels to each timeline entry.',
          'Draft an executive incident narrative with unsupported claims removed.'
        ],
        evidence: 'Timeline with confidence labels and a one-page incident narrative.'
      },
      {
        title: '4. Dashboard decision review',
        time: '30 min',
        mission: 'Defend the dashboard before a mock steering committee.',
        steps: [
          'Explain which decisions the dashboard enables: allocate budget, prioritize recovery, communicate risk, or escalate.',
          'Show three widgets: service health, evidence confidence, and response backlog.',
          'Document what humans must approve before AI-generated text is used externally.',
          'Record two dashboard failure modes and mitigations.'
        ],
        evidence: 'Dashboard storyboard, governance notes, and steering-committee defense.'
      }
    ],
    toolkit: [
      { label: 'Roles', detail: 'Incident commander, service owner, evidence analyst, dashboard designer, communications reviewer.' },
      { label: 'Free tools', detail: 'Google Sheets/LibreOffice, Looker Studio/Metabase, Mermaid, browser research, optional local LLM.' },
      { label: 'Core artifacts', detail: 'Evidence register, service impact matrix, timeline, dashboard storyboard, executive summary.' },
      { label: 'Management lens', detail: 'Prioritisation, accountability, communication quality, risk acceptance, auditability.' }
    ],
    dataset: {
      title: 'Mini incident dataset for classroom simulation',
      headers: ['ID', 'Signal', 'Service', 'Confidence', 'Management action'],
      rows: [
        ['E01', 'Authentication latency rises above baseline', 'Citizen portal', 'High', 'Prioritize identity dependency check'],
        ['E02', 'Media reports immigration service disruption', 'Immigration', 'Medium', 'Verify with internal owner before public statement'],
        ['E03', 'Backup restore estimate changes twice', 'Core infrastructure', 'Low', 'Escalate uncertainty and request recovery evidence'],
        ['E04', 'Vendor advisory mentions ransomware pattern', 'Data center', 'Medium', 'Map to containment checklist'],
        ['E05', 'Manual workaround created at airport desk', 'Border service', 'High', 'Track business continuity capacity']
      ]
    },
    commands: [
      { label: 'Dashboard metric formula', code: 'Priority Score = (Impact x 0.4) + (Urgency x 0.3) + (Confidence Gap x 0.2) + (Public Exposure x 0.1)' },
      { label: 'AI prompt pattern', code: 'Summarize claims C01-C10 for an executive. Use only provided claim IDs. Mark unsupported statements as UNKNOWN. Output: risk, evidence, decision needed.' }
    ],
    quiz: [
      { q: 'Which dashboard widget best supports executive decision-making?', options: ['A colorful pie chart of all news mentions', 'A service impact matrix with owner, severity, confidence, and next action', 'A raw log dump', 'A list of every social-media post'], answer: 'A service impact matrix with owner, severity, confidence, and next action', explain: 'Management dashboards should connect evidence to ownership and action.' },
      { q: 'What is the biggest risk of AI summarisation during an incident?', options: ['It is too fast', 'It may merge uncertain claims into confident language', 'It cannot read text', 'It removes the need for humans'], answer: 'It may merge uncertain claims into confident language', explain: 'The lab requires confidence labels and human approval to prevent false certainty.' }
    ],
    rubric: [
      { criterion: 'Evidence discipline', excellent: 'Claims are traceable, scored, and uncertainty is visible.', points: '25%' },
      { criterion: 'Dashboard usefulness', excellent: 'Every widget supports a named management decision.', points: '30%' },
      { criterion: 'Incident reasoning', excellent: 'Timeline, service impact, and recommendations are coherent.', points: '25%' },
      { criterion: 'Governance', excellent: 'AI use has approval gates, limitations, and audit notes.', points: '20%' }
    ],
    deliverables: ['Interactive dashboard or storyboard', 'Evidence register spreadsheet', 'Executive incident brief', 'AI prompt and validation log', 'Peer-review notes']
  },
  'youcom-hands-on-lab-communication-protocols-wireshark-iot': {
    slug: 'youcom-hands-on-lab-communication-protocols-wireshark-iot',
    kitSlug: 'communication-protocols-iot',
    runtimeId: 'protocol',
    eyebrow: 'Communication Protocol Interactive Lab',
    title: 'Wireshark + IoT Protocol Reliability Lab',
    duration: '120–180 minutes',
    scenario: 'Students troubleshoot an Indonesian smart-agriculture sensor network where soil-moisture alerts arrive late or disappear. They inspect DNS, TCP, UDP, HTTP, TLS, and MQTT evidence and recommend protocol changes.',
    outcomes: [
      'Read packet-level evidence instead of memorising protocol definitions.',
      'Compare reliability, latency, overhead, encryption visibility, and operational fit across protocols.',
      'Use Wireshark display filters to isolate flows and explain failures.',
      'Design a protocol decision matrix for IoT monitoring in constrained environments.'
    ],
    stations: [
      {
        title: '1. Capture orientation',
        time: '20 min',
        mission: 'Identify endpoints, conversations, and protocol mix in a simulated IoT trace.',
        steps: ['List top talkers and destination ports.', 'Filter DNS queries and identify broker/cloud endpoints.', 'Separate control-plane traffic from sensor payload traffic.', 'Record evidence screenshots with filter strings.'],
        evidence: 'Protocol inventory sheet with endpoint, port, filter, and observation.'
      },
      {
        title: '2. DNS, TCP, and TLS chain',
        time: '35 min',
        mission: 'Trace how a device finds and establishes a secure session with the cloud.',
        steps: ['Filter dns and identify lookup latency or repeated queries.', 'Follow the TCP handshake and identify retransmissions.', 'Locate TLS ClientHello and SNI where visible.', 'Explain what TLS hides and what metadata remains visible.'],
        evidence: 'Annotated connection sequence diagram.'
      },
      {
        title: '3. MQTT reliability experiment',
        time: '45 min',
        mission: 'Compare MQTT QoS behavior when the sensor link is unstable.',
        steps: ['Filter mqtt and identify CONNECT, SUBSCRIBE, PUBLISH, PUBACK flows.', 'Compare QoS 0 and QoS 1 delivery evidence.', 'Explain retained messages and topic hierarchy.', 'Recommend QoS level for moisture-alert vs periodic telemetry messages.'],
        evidence: 'MQTT decision table and packet screenshot set.'
      },
      {
        title: '4. Protocol architecture recommendation',
        time: '30 min',
        mission: 'Produce a defensible communication design for farmers, cloud operators, and maintainers.',
        steps: ['Score HTTP polling, MQTT, and UDP telemetry against reliability/security/overhead.', 'Identify when not to use each protocol.', 'Add monitoring metrics: retransmissions, broker disconnects, message age, packet loss.', 'Present final recommendation with assumptions.'],
        evidence: 'Protocol decision matrix and architecture sketch.'
      }
    ],
    toolkit: [
      { label: 'Roles', detail: 'Packet analyst, IoT engineer, security reviewer, farm-operations owner, presenter.' },
      { label: 'Free tools', detail: 'Wireshark, Mosquitto, MQTT Explorer, Python paho-mqtt, tcpdump, optional Docker.' },
      { label: 'Core filters', detail: 'dns, tcp.analysis.retransmission, tls, mqtt, http, udp, ip.addr == x.x.x.x.' },
      { label: 'Design lens', detail: 'Reliability, bandwidth, power use, security, observability, field maintenance.' }
    ],
    dataset: {
      title: 'Protocol evidence cards',
      headers: ['Observation', 'Likely protocol clue', 'Risk', 'Action'],
      rows: [
        ['Repeated name lookup before publish', 'DNS', 'Delay before data upload', 'Cache broker address or inspect resolver'],
        ['SYN followed by retransmission', 'TCP', 'Network loss or blocked path', 'Check route, firewall, signal quality'],
        ['Payload unreadable but SNI visible', 'TLS', 'Encrypted content limits inspection', 'Use endpoint logs plus metadata'],
        ['PUBLISH without PUBACK', 'MQTT QoS 1 problem', 'Alert may not be confirmed', 'Review broker/client retry settings'],
        ['Fast datagram with no retry', 'UDP', 'Low overhead but weak delivery proof', 'Use only for non-critical telemetry']
      ]
    },
    commands: [
      { label: 'Generate MQTT messages locally', code: 'mosquitto_sub -h test.mosquitto.org -t campus/farm/soil/#\nmosquitto_pub -h test.mosquitto.org -t campus/farm/soil/moisture -m "plot=A1,value=27" -q 1' },
      { label: 'Wireshark filter set', code: 'dns || mqtt || http || tls || tcp.analysis.retransmission\nmqtt.msgtype == 3\ntcp.port == 1883 || tcp.port == 8883' }
    ],
    quiz: [
      { q: 'Why might MQTT be preferred over repeated HTTP polling for IoT telemetry?', options: ['It is always encrypted by default', 'It supports lightweight publish-subscribe communication with QoS options', 'It does not use networking', 'It replaces DNS'], answer: 'It supports lightweight publish-subscribe communication with QoS options', explain: 'MQTT is designed for lightweight message distribution and delivery semantics.' },
      { q: 'What can Wireshark still reveal when TLS encrypts the payload?', options: ['Every sensor value', 'Some metadata such as IPs, timing, packet sizes, and sometimes SNI', 'The private key', 'Nothing at all'], answer: 'Some metadata such as IPs, timing, packet sizes, and sometimes SNI', explain: 'Encryption hides content but not all traffic metadata.' }
    ],
    rubric: [
      { criterion: 'Packet evidence', excellent: 'Findings include filters, packet numbers/screenshots, and accurate interpretation.', points: '30%' },
      { criterion: 'Protocol comparison', excellent: 'Trade-offs are concrete and tied to the smart-agriculture scenario.', points: '30%' },
      { criterion: 'Troubleshooting logic', excellent: 'Students distinguish symptoms, causes, and verification steps.', points: '25%' },
      { criterion: 'Communication clarity', excellent: 'Recommendation is understandable to technical and non-technical stakeholders.', points: '15%' }
    ],
    deliverables: ['Wireshark evidence workbook', 'Annotated connection diagram', 'MQTT QoS experiment notes', 'Protocol decision matrix', 'Final architecture recommendation']
  },
  'youcom-hands-on-lab-ai-rag-chatbot': {
    slug: 'youcom-hands-on-lab-ai-rag-chatbot',
    kitSlug: 'ai-rag-chatbot',
    runtimeId: 'ai',
    eyebrow: 'Artificial Intelligence Interactive Lab',
    title: 'Responsible RAG Chatbot Evaluation Studio',
    duration: '150–180 minutes',
    scenario: 'Students build and evaluate a university-policy assistant that must answer only from provided policy snippets. The focus is not just making a chatbot work, but proving citation quality, refusal behavior, and hallucination controls.',
    outcomes: [
      'Explain the RAG pipeline: chunking, embeddings, retrieval, generation, citation, and evaluation.',
      'Build a minimal local or notebook-based retrieval workflow using policy snippets.',
      'Measure answer faithfulness, citation coverage, refusal quality, and unsupported-claim risk.',
      'Design human-in-the-loop controls for responsible AI deployment in academic services.'
    ],
    stations: [
      {
        title: '1. Knowledge-base design',
        time: '30 min',
        mission: 'Prepare policy snippets so retrieval can be audited.',
        steps: ['Assign each policy paragraph a source ID.', 'Chunk by rule boundaries rather than arbitrary length only.', 'Add metadata: policy area, date, owner, audience.', 'Create five questions that should be answerable and five that should be refused.'],
        evidence: 'Policy corpus sheet with source IDs and test question set.'
      },
      {
        title: '2. Retrieval and citation build',
        time: '45 min',
        mission: 'Implement or simulate retrieval before generation.',
        steps: ['Retrieve top matching snippets for a question.', 'Force the answer template to cite source IDs.', 'Display retrieved context before final answer.', 'Log cases where retrieved context is weak or conflicting.'],
        evidence: 'Working notebook/prototype or retrieval simulation log.'
      },
      {
        title: '3. Hallucination challenge bench',
        time: '45 min',
        mission: 'Attack the chatbot with ambiguous, missing-policy, and adversarial questions.',
        steps: ['Test unsupported questions and verify refusal behavior.', 'Identify intrinsic hallucination: answer contradicts retrieved source.', 'Identify extrinsic hallucination: answer adds facts not present in source.', 'Improve the prompt/control policy and retest.'],
        evidence: 'Evaluation matrix with before/after results.'
      },
      {
        title: '4. Responsible deployment review',
        time: '30 min',
        mission: 'Decide whether the assistant is safe enough for student-facing use.',
        steps: ['Define allowed and forbidden use cases.', 'Add escalation paths for high-stakes questions.', 'Write a transparency notice for users.', 'Present risk controls to a mock academic board.'],
        evidence: 'Responsible AI deployment memo.'
      }
    ],
    toolkit: [
      { label: 'Roles', detail: 'RAG engineer, policy owner, evaluator, student user, ethics reviewer.' },
      { label: 'Free tools', detail: 'Python notebook, scikit-learn TF-IDF retrieval, optional Ollama, local markdown policy snippets.' },
      { label: 'Metrics', detail: 'Citation precision, answer faithfulness, refusal accuracy, context relevance, escalation correctness.' },
      { label: 'Governance lens', detail: 'Transparency, accountability, privacy, human oversight, audit logs.' }
    ],
    dataset: {
      title: 'Policy snippet mini-corpus',
      headers: ['Source ID', 'Policy area', 'Snippet', 'Risk if misanswered'],
      rows: [
        ['P01', 'Attendance', 'Students must satisfy minimum attendance requirements defined by the course policy.', 'Medium'],
        ['P02', 'Assessment', 'Final grades combine assignments, midterm, final exam, and lecturer-approved participation.', 'High'],
        ['P03', 'Appeal', 'Grade appeals require documented evidence and submission within the stated academic window.', 'High'],
        ['P04', 'Privacy', 'Student academic data must not be exposed to unauthorized parties.', 'Critical'],
        ['P05', 'Scope', 'The assistant cannot approve exceptions; it can only explain published policy and direct users to staff.', 'Critical']
      ]
    },
    commands: [
      { label: 'Minimal retrieval baseline', code: 'from sklearn.feature_extraction.text import TfidfVectorizer\nfrom sklearn.metrics.pairwise import cosine_similarity\n# Fit snippets, rank top-k, then answer only from returned source IDs.' },
      { label: 'Answer contract', code: 'If the provided context does not contain the answer, say: "I cannot answer from the provided policy sources." Always include Source IDs.' }
    ],
    quiz: [
      { q: 'What makes a RAG answer more trustworthy?', options: ['Longer text', 'Citations that map to retrieved source IDs and support the claim', 'A confident tone', 'No refusal behavior'], answer: 'Citations that map to retrieved source IDs and support the claim', explain: 'Trust depends on source-grounded claims, not style.' },
      { q: 'Which test question is best for evaluating refusal behavior?', options: ['What does P01 say about attendance?', 'Invent a policy exception for my late final exam', 'Summarize the attendance snippet', 'Quote source P02'], answer: 'Invent a policy exception for my late final exam', explain: 'Unsupported or policy-creating prompts reveal whether the assistant refuses safely.' }
    ],
    rubric: [
      { criterion: 'RAG architecture', excellent: 'Pipeline shows corpus, retrieval, context, answer, and citation trace.', points: '30%' },
      { criterion: 'Evaluation depth', excellent: 'Tests include answerable, unanswerable, conflicting, and adversarial cases.', points: '30%' },
      { criterion: 'Responsible AI controls', excellent: 'Refusal, escalation, transparency, and logging are specified.', points: '25%' },
      { criterion: 'Prototype clarity', excellent: 'Code/simulation is reproducible and easy to explain.', points: '15%' }
    ],
    deliverables: ['Policy mini-corpus', 'RAG prototype or simulation', 'Hallucination evaluation matrix', 'Responsible deployment memo', 'Demo script']
  }
};

const { slug } = Astro.props;
const lab = labs[slug as string];
---
{lab && (
  <section class="interactive-lab mb-8 overflow-hidden rounded-[2rem] border border-cyan-300/20 bg-slate-950/80 shadow-2xl shadow-cyan-950/40">
    <div class="relative border-b border-white/10 bg-[radial-gradient(circle_at_top_left,rgba(34,211,238,0.25),transparent_35%),linear-gradient(135deg,rgba(15,23,42,0.95),rgba(30,41,59,0.85))] p-8">
      <p class="text-xs font-bold uppercase tracking-[0.35em] text-cyan-200">{lab.eyebrow}</p>
      <h2 class="mt-3 text-3xl font-black text-white md:text-5xl">{lab.title}</h2>
      <p class="mt-4 max-w-4xl text-base leading-8 text-slate-200">{lab.scenario}</p>
      <div class="mt-6 flex flex-wrap gap-3 text-sm">
        <span class="rounded-full bg-cyan-400/15 px-4 py-2 font-semibold text-cyan-100">Duration: {lab.duration}</span>
        <span class="rounded-full bg-emerald-400/15 px-4 py-2 font-semibold text-emerald-100">Native Python runnable lab</span>
        <span class="rounded-full bg-violet-400/15 px-4 py-2 font-semibold text-violet-100">Test with Wireshark / Postman / n8n</span>
      </div>
      <div class="mt-8 rounded-3xl border border-white/10 bg-black/30 p-5">
        <h3 class="text-lg font-black text-white">Auto-start Worker Lab Runtime</h3>
        <p class="mt-2 text-sm leading-6 text-slate-300">When this page loads, it automatically calls the Cloudflare Worker runtime for this topic. Students can immediately test the online API in the browser, Postman, or n8n. The downloadable native Python version remains available for local execution and Wireshark loopback capture.</p>
        <div class="mt-4 rounded-2xl border border-emerald-300/20 bg-emerald-400/10 p-4 text-sm text-emerald-100">
          <p class="font-bold">Live runtime status</p>
          <p class="lab-runtime-status mt-1 break-words text-emerald-50" data-runtime-id={lab.runtimeId}>Starting Worker runtime…</p>
          <ul class="lab-runtime-tests mt-3 space-y-1 text-xs text-emerald-50" data-runtime-id={lab.runtimeId}>
            <li>Running endpoint diagnostics…</li>
          </ul>
        </div>
        <div class="mt-4 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
          <a class="rounded-2xl border border-emerald-300/20 bg-emerald-400/10 p-4 text-sm font-semibold text-emerald-100 transition hover:bg-emerald-400/20" href={`https://lecturer-materials.hicall.workers.dev/api/labs/${lab.runtimeId}/start`}>Start / health API</a>
          <a class="rounded-2xl border border-cyan-300/20 bg-cyan-400/10 p-4 text-sm font-semibold text-cyan-100 transition hover:bg-cyan-400/20" href={`https://lecturer-materials.hicall.workers.dev/api/labs/${lab.runtimeId}/${lab.runtimeId === 'ism' ? 'kpis' : lab.runtimeId === 'protocol' ? 'metrics' : 'sources'}`}>Open live data endpoint</a>
          <button type="button" class="lab-runtime-copy rounded-2xl border border-violet-300/20 bg-violet-400/10 p-4 text-left text-sm font-semibold text-violet-100 transition hover:bg-violet-400/20" data-copy={`https://lecturer-materials.hicall.workers.dev/api/labs/${lab.runtimeId}/start`}>Copy API base</button>
          <span class="rounded-2xl border border-white/10 bg-white/[0.04] p-4 text-sm font-semibold text-slate-200">Works with Postman + n8n HTTP Request</span>
        </div>
      </div>

      <div class="mt-6 rounded-3xl border border-white/10 bg-black/30 p-5">
        <h3 class="text-lg font-black text-white">Native Python Testing Kit</h3>
        <p class="mt-2 text-sm leading-6 text-slate-300">Run the lab locally with Python only, then validate it using Postman requests, n8n automation, and Wireshark traffic evidence.</p>
        <div class="mt-4 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
          <a class="rounded-2xl border border-cyan-300/20 bg-cyan-400/10 p-4 text-sm font-semibold text-cyan-100 transition hover:bg-cyan-400/20" href={`/downloads/native-python-lab-kits/${lab.kitSlug}/README.md`}>README / run guide</a>
          <a class="rounded-2xl border border-emerald-300/20 bg-emerald-400/10 p-4 text-sm font-semibold text-emerald-100 transition hover:bg-emerald-400/20" href={`/downloads/native-python-lab-kits/${lab.kitSlug}/postman_collection.json`}>Local Postman collection</a>
          <a class="rounded-2xl border border-sky-300/20 bg-sky-400/10 p-4 text-sm font-semibold text-sky-100 transition hover:bg-sky-400/20" href={`/downloads/native-python-lab-kits/${lab.kitSlug}/postman_worker_collection.json`}>Online Worker Postman</a>
          <a class="rounded-2xl border border-violet-300/20 bg-violet-400/10 p-4 text-sm font-semibold text-violet-100 transition hover:bg-violet-400/20" href={`/downloads/native-python-lab-kits/${lab.kitSlug}/n8n_workflow.json`}>Local n8n workflow</a>
          <a class="rounded-2xl border border-fuchsia-300/20 bg-fuchsia-400/10 p-4 text-sm font-semibold text-fuchsia-100 transition hover:bg-fuchsia-400/20" href={`/downloads/native-python-lab-kits/${lab.kitSlug}/n8n_worker_workflow.json`}>Online Worker n8n</a>
          <a class="rounded-2xl border border-orange-300/20 bg-orange-400/10 p-4 text-sm font-semibold text-orange-100 transition hover:bg-orange-400/20" href={`/downloads/native-python-lab-kits/${lab.kitSlug}/wireshark_filters.txt`}>Wireshark filters</a>
        </div>
        {lab.kitSlug === 'communication-protocols-iot' && (
          <a class="mt-3 inline-flex rounded-2xl border border-rose-300/20 bg-rose-400/10 px-4 py-3 text-sm font-semibold text-rose-100 transition hover:bg-rose-400/20" href="/downloads/native-python-lab-kits/communication-protocols-iot/iot_protocol_lab.pcap">Download generated Wireshark PCAP</a>
        )}
      </div>
    </div>

    <div class="grid gap-6 p-6 lg:grid-cols-[0.95fr_1.05fr]">
      <div class="space-y-6">
        <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-6">
          <h3 class="text-xl font-bold text-white">Learning outcomes</h3>
          <div class="mt-4 space-y-3">
            {lab.outcomes.map((outcome, index) => (
              <label class="flex cursor-pointer gap-3 rounded-2xl border border-white/10 bg-slate-900/70 p-3 text-sm leading-6 text-slate-200 transition hover:border-cyan-300/40">
                <input class="lab-check mt-1 h-4 w-4 rounded border-slate-500 bg-slate-800 text-cyan-400" type="checkbox" data-lab={lab.slug} />
                <span><strong class="text-cyan-200">Outcome {index + 1}:</strong> {outcome}</span>
              </label>
            ))}
          </div>
          <div class="mt-5 h-3 overflow-hidden rounded-full bg-slate-800">
            <div class="lab-progress h-full w-0 rounded-full bg-gradient-to-r from-cyan-400 to-emerald-400 transition-all" data-lab={lab.slug}></div>
          </div>
          <p class="lab-progress-label mt-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-400" data-lab={lab.slug}>0% checked</p>
        </div>

        <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-6">
          <h3 class="text-xl font-bold text-white">Instructor toolkit</h3>
          <div class="mt-4 grid gap-3">
            {lab.toolkit.map((item) => (
              <details class="group rounded-2xl border border-white/10 bg-slate-900/70 p-4">
                <summary class="cursor-pointer font-semibold text-cyan-100">{item.label}</summary>
                <p class="mt-3 text-sm leading-6 text-slate-300">{item.detail}</p>
              </details>
            ))}
          </div>
        </div>
      </div>

      <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-6">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <h3 class="text-xl font-bold text-white">Hands-on station board</h3>
          <span class="rounded-full bg-orange-400/15 px-3 py-1 text-xs font-bold uppercase tracking-[0.2em] text-orange-100">Run in teams</span>
        </div>
        <div class="mt-5 space-y-4">
          {lab.stations.map((station, index) => (
            <details class="rounded-3xl border border-white/10 bg-slate-900/80 p-5" open={index === 0}>
              <summary class="cursor-pointer list-none">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div>
                    <p class="text-xs font-bold uppercase tracking-[0.25em] text-cyan-300">{station.time}</p>
                    <h4 class="mt-1 text-lg font-bold text-white">{station.title}</h4>
                  </div>
                  <span class="rounded-full bg-white/10 px-3 py-1 text-xs text-slate-200">Station {index + 1}</span>
                </div>
                <p class="mt-3 text-sm leading-6 text-slate-300">{station.mission}</p>
              </summary>
              <ol class="mt-4 space-y-2 pl-5 text-sm leading-6 text-slate-200">
                {station.steps.map((step) => <li class="list-decimal">{step}</li>)}
              </ol>
              <p class="mt-4 rounded-2xl border border-emerald-300/20 bg-emerald-400/10 p-3 text-sm text-emerald-100"><strong>Evidence:</strong> {station.evidence}</p>
            </details>
          ))}
        </div>
      </div>
    </div>

    <div class="grid gap-6 border-t border-white/10 p-6 lg:grid-cols-2">
      <div class="rounded-3xl border border-white/10 bg-slate-900/70 p-6">
        <h3 class="text-xl font-bold text-white">{lab.dataset.title}</h3>
        <div class="mt-4 overflow-x-auto">
          <table class="min-w-full text-left text-sm text-slate-200">
            <thead class="text-xs uppercase tracking-[0.2em] text-cyan-200">
              <tr>{lab.dataset.headers.map((header) => <th class="border-b border-white/10 px-3 py-2">{header}</th>)}</tr>
            </thead>
            <tbody>
              {lab.dataset.rows.map((row) => (
                <tr class="border-b border-white/5">{row.map((cell) => <td class="px-3 py-3 align-top">{cell}</td>)}</tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <div class="rounded-3xl border border-white/10 bg-slate-900/70 p-6">
        <h3 class="text-xl font-bold text-white">Copy-ready lab assets</h3>
        <div class="mt-4 space-y-4">
          {lab.commands.map((command) => (
            <div class="rounded-2xl border border-white/10 bg-black/40 p-4">
              <div class="mb-2 flex items-center justify-between gap-3">
                <p class="text-sm font-semibold text-cyan-100">{command.label}</p>
                <button class="copy-btn rounded-full bg-cyan-400/15 px-3 py-1 text-xs font-bold text-cyan-100" type="button" data-copy={command.code}>Copy</button>
              </div>
              <pre class="whitespace-pre-wrap text-xs leading-6 text-slate-200"><code>{command.code}</code></pre>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="grid gap-6 border-t border-white/10 p-6 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="rounded-3xl border border-white/10 bg-slate-900/70 p-6">
        <h3 class="text-xl font-bold text-white">Self-check quiz</h3>
        <div class="mt-4 space-y-4">
          {lab.quiz.map((item, index) => (
            <div class="quiz-card rounded-2xl border border-white/10 bg-slate-950/60 p-4" data-answer={item.answer}>
              <p class="font-semibold text-white">{index + 1}. {item.q}</p>
              <div class="mt-3 grid gap-2">
                {item.options.map((option) => <button type="button" class="quiz-option rounded-xl border border-white/10 bg-white/[0.03] px-3 py-2 text-left text-sm text-slate-200 hover:border-cyan-300/50">{option}</button>)}
              </div>
              <p class="quiz-feedback mt-3 hidden rounded-xl p-3 text-sm"></p>
              <p class="mt-2 text-xs leading-5 text-slate-400">{item.explain}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="rounded-3xl border border-white/10 bg-slate-900/70 p-6">
        <h3 class="text-xl font-bold text-white">Assessment rubric</h3>
        <div class="mt-4 space-y-3">
          {lab.rubric.map((row) => (
            <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
              <div class="flex items-center justify-between gap-3">
                <p class="font-semibold text-cyan-100">{row.criterion}</p>
                <span class="rounded-full bg-white/10 px-3 py-1 text-xs text-slate-200">{row.points}</span>
              </div>
              <p class="mt-2 text-sm leading-6 text-slate-300">{row.excellent}</p>
            </div>
          ))}
        </div>
        <h4 class="mt-6 font-bold text-white">Student deliverables</h4>
        <ul class="mt-3 space-y-2 text-sm text-slate-200">
          {lab.deliverables.map((item) => <li class="flex gap-2"><span class="text-emerald-300">✓</span>{item}</li>)}
        </ul>
      </div>
    </div>
  </section>
)}

<script>
  // @ts-nocheck
  const updateProgress = (labId) => {
    const checks = Array.from(document.querySelectorAll(`.lab-check[data-lab="${labId}"]`));
    const done = checks.filter((item) => item.checked).length;
    const pct = checks.length ? Math.round((done / checks.length) * 100) : 0;
    document.querySelectorAll(`.lab-progress[data-lab="${labId}"]`).forEach((bar) => { bar.style.width = `${pct}%`; });
    document.querySelectorAll(`.lab-progress-label[data-lab="${labId}"]`).forEach((label) => { label.textContent = `${pct}% checked`; });
  };

  document.querySelectorAll('.lab-check').forEach((check) => {
    check.addEventListener('change', () => updateProgress(check.dataset.lab));
  });

  document.querySelectorAll('.copy-btn, .lab-runtime-copy').forEach((button) => {
    button.addEventListener('click', async () => {
      await navigator.clipboard.writeText(button.dataset.copy || '');
      const original = button.textContent;
      button.textContent = 'Copied';
      setTimeout(() => { button.textContent = original; }, 1200);
    });
  });

  const runtimeTestPlan = {
    ism: [
      { label: 'Start runtime', method: 'GET', path: 'start' },
      { label: 'Read KPIs', method: 'GET', path: 'kpis' },
      { label: 'Read incidents', method: 'GET', path: 'incidents' },
      { label: 'Create incident', method: 'POST', path: 'incidents', body: { service: 'Browser diagnostic', signal: 'Student page runtime check', severity: 4, confidence: 0.77 } }
    ],
    protocol: [
      { label: 'Start runtime', method: 'GET', path: 'start' },
      { label: 'Read metrics', method: 'GET', path: 'metrics' },
      { label: 'Publish telemetry', method: 'POST', path: 'publish', body: { topic: 'farm/alert/critical', value: 'browser-check', qos: 1, critical: true } }
    ],
    ai: [
      { label: 'Start runtime', method: 'GET', path: 'start' },
      { label: 'Read sources', method: 'GET', path: 'sources' },
      { label: 'Ask grounded question', method: 'POST', path: 'ask', body: { question: 'How are final grades calculated?' } },
      { label: 'Test safe refusal', method: 'POST', path: 'ask', body: { question: 'Approve an exception and change my grade' } }
    ]
  };

  const callRuntime = async (runtimeId, test) => {
    const url = `https://lecturer-materials.hicall.workers.dev/api/labs/${runtimeId}/${test.path}`;
    const response = await fetch(url, {
      method: test.method,
      headers: test.body ? { 'content-type': 'application/json' } : undefined,
      body: test.body ? JSON.stringify(test.body) : undefined
    });
    const data = await response.json();
    if (!response.ok || data.ok === false) {
      throw new Error(data.error || `HTTP ${response.status}`);
    }
    return data;
  };

  document.querySelectorAll('.lab-runtime-status').forEach(async (status) => {
    const runtimeId = status.dataset.runtimeId;
    try {
      const data = await callRuntime(runtimeId, { method: 'GET', path: 'start' });
      status.textContent = `Online: ${data.title} started normally on Cloudflare Worker. API: ${data.baseUrl}`;
    } catch (error) {
      status.textContent = `Worker runtime not reachable. ${error}`;
    }
  });

  document.querySelectorAll('.lab-runtime-tests').forEach(async (list) => {
    const runtimeId = list.dataset.runtimeId;
    const tests = runtimeTestPlan[runtimeId] || [];
    list.innerHTML = '';
    let passed = 0;
    for (const test of tests) {
      const item = document.createElement('li');
      item.textContent = `⏳ ${test.label}`;
      list.appendChild(item);
      try {
        await callRuntime(runtimeId, test);
        passed += 1;
        item.textContent = `✅ ${test.label}`;
      } catch (error) {
        item.textContent = `❌ ${test.label}: ${error}`;
      }
    }
    const summary = document.createElement('li');
    summary.className = 'font-bold';
    summary.textContent = passed === tests.length
      ? `✅ All ${passed}/${tests.length} live functions are running normally.`
      : `⚠️ ${passed}/${tests.length} live functions passed. Check failed items above.`;
    list.appendChild(summary);
  });

  document.querySelectorAll('.quiz-card').forEach((card) => {
    const answer = card.dataset.answer;
    const feedback = card.querySelector('.quiz-feedback');
    card.querySelectorAll('.quiz-option').forEach((option) => {
      option.addEventListener('click', () => {
        const correct = option.textContent === answer;
        card.querySelectorAll('.quiz-option').forEach((btn) => btn.classList.remove('border-emerald-300/70', 'border-rose-300/70'));
        option.classList.add(correct ? 'border-emerald-300/70' : 'border-rose-300/70');
        feedback.classList.remove('hidden', 'bg-emerald-400/10', 'text-emerald-100', 'bg-rose-400/10', 'text-rose-100');
        feedback.classList.add(correct ? 'bg-emerald-400/10' : 'bg-rose-400/10', correct ? 'text-emerald-100' : 'text-rose-100');
        feedback.textContent = correct ? 'Correct — this answer is supported by the lab logic.' : `Not quite. Best answer: ${answer}`;
      });
    });
  });
</script>
