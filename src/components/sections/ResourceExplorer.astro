---
interface ResourceItem {
  title: string;
  slug: string;
  summary: string;
  topic: string;
  level: string;
  format: string;
  tags: string[];
  downloadUrl?: string;
  ctaLabel?: string;
}
interface Props {
  resources: ResourceItem[];
  title?: string;
  description?: string;
}
const { resources, title = 'Interactive resource explorer', description = 'Filter by topic, preview the learning value, and open or download the most relevant material.' } = Astro.props;
const filters = ['All', 'Information System Management', 'Communication Protocol', 'Artificial Intelligence'];
---
<section id="resource-explorer" class="py-20" data-resource-explorer>
  <div class="container-shell">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-brand-200">Resource explorer</p>
      <h2 class="mt-4 text-4xl font-semibold tracking-tight text-white sm:text-5xl">{title}</h2>
      <p class="mt-4 text-base leading-8 text-slate-300">{description}</p>
    </div>
    <div class="mt-8 flex flex-wrap gap-3">
      {filters.map((filter, index) => (
        <button
          type="button"
          data-resource-filter={filter}
          aria-pressed={index === 0 ? 'true' : 'false'}
          class={`rounded-full px-5 py-3 text-sm font-semibold transition ${index === 0 ? 'bg-white text-slate-950' : 'border border-white/10 bg-white/5 text-slate-100 hover:border-white/20 hover:bg-white/10'}`}
        >
          {filter}
        </button>
      ))}
    </div>
    <div class="mt-10 grid gap-6 lg:grid-cols-3">
      {resources.map((resource) => (
        <article data-resource-card={resource.topic} class="card-surface flex h-full flex-col p-6">
          <div class="flex items-center justify-between gap-3 text-xs uppercase tracking-[0.24em] text-slate-400">
            <span>{resource.topic}</span>
            <span>{resource.format}</span>
          </div>
          <h3 class="mt-4 text-2xl font-semibold text-white">{resource.title}</h3>
          <p class="mt-3 text-sm leading-7 text-slate-300">{resource.summary}</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {resource.tags.slice(0, 3).map((tag) => <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-slate-200">{tag}</span>)}
          </div>
          <div class="mt-6 flex items-center justify-between gap-3 text-sm text-slate-300">
            <span>{resource.level}</span>
            <span class="rounded-full border border-emerald-400/20 bg-emerald-400/10 px-3 py-1 text-emerald-200">Ready to use</span>
          </div>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href={`/resources/${resource.slug}`} class="rounded-full bg-brand-500 px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-400">Open</a>
            {resource.downloadUrl && <a href={resource.downloadUrl} download class="rounded-full border border-white/15 px-4 py-2 text-sm font-semibold text-slate-100 transition hover:border-white/30 hover:bg-white/5">{resource.ctaLabel ?? 'Download'}</a>}
          </div>
        </article>
      ))}
    </div>
  </div>

  <script is:inline>
    document.querySelectorAll('[data-resource-explorer]').forEach((explorer) => {
      const buttons = Array.from(explorer.querySelectorAll('[data-resource-filter]'));
      const cards = Array.from(explorer.querySelectorAll('[data-resource-card]'));
      const applyFilter = (value) => {
        buttons.forEach((button) => {
          const active = button.dataset.resourceFilter === value;
          button.setAttribute('aria-pressed', String(active));
          button.classList.toggle('bg-white', active);
          button.classList.toggle('text-slate-950', active);
          button.classList.toggle('border', !active);
          button.classList.toggle('border-white/10', !active);
          button.classList.toggle('bg-white/5', !active);
          button.classList.toggle('text-slate-100', !active);
        });
        cards.forEach((card) => {
          const topic = card.dataset.resourceCard;
          const visible = value === 'All' || topic === value;
          card.classList.toggle('hidden', !visible);
        });
      };
      buttons.forEach((button) => button.addEventListener('click', () => applyFilter(button.dataset.resourceFilter)));
    });
  </script>
</section>
