---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}
const { eyebrow, title, description } = Astro.props;
---
<div class="max-w-3xl">
  <p class="text-sm font-semibold uppercase tracking-[0.3em] text-brand-200">{eyebrow}</p>
  <h2 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-4xl">{title}</h2>
  <p class="mt-4 text-base leading-7 text-slate-300">{description}</p>
</div>
