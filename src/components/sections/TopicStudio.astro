---
interface TopicItem {
  title: string;
  slug: string;
  summary: string;
  importance: string;
  subtopics: string[];
  learningOutcomes: string[];
}
interface Props {
  topics: TopicItem[];
}
const { topics } = Astro.props;
---
<section id="topic-studio" class="py-20" data-topic-studio>
  <div class="container-shell">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-brand-200">Topic studio</p>
        <h2 class="mt-4 text-4xl font-semibold tracking-tight text-white sm:text-5xl">Switch between lecturer pillars like a learning app, not a static brochure.</h2>
        <p class="mt-4 text-base leading-8 text-slate-300">Inspired by the energy of modern learning platforms, this section gives each topic its own spotlight, outcomes, and action path.</p>
      </div>
      <div class="flex flex-wrap gap-3">
        {topics.map((topic, index) => (
          <button
            type="button"
            data-topic-tab={topic.slug}
            aria-pressed={index === 0 ? 'true' : 'false'}
            class={`rounded-full px-5 py-3 text-sm font-semibold transition ${index === 0 ? 'bg-white text-slate-950' : 'border border-white/10 bg-white/5 text-slate-100 hover:border-white/20 hover:bg-white/10'}`}
          >
            {topic.title}
          </button>
        ))}
      </div>
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-[1.08fr_0.92fr]">
      {topics.map((topic, index) => (
        <article data-topic-panel={topic.slug} class={`${index === 0 ? 'grid' : 'hidden'} gap-6 lg:col-span-2 lg:grid-cols-[1.08fr_0.92fr]`}>
          <div class="card-surface p-8 sm:p-10">
            <div class="flex flex-wrap items-center gap-3 text-xs uppercase tracking-[0.25em] text-slate-400">
              <span>Focus area</span>
              <span>•</span>
              <span>{topic.title}</span>
            </div>
            <h3 class="mt-4 text-3xl font-semibold text-white sm:text-4xl">{topic.summary}</h3>
            <p class="mt-5 text-base leading-8 text-slate-300">{topic.importance}</p>
            <div class="mt-8 grid gap-4 sm:grid-cols-3">
              <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
                <p class="text-xs uppercase tracking-[0.24em] text-fuchsia-200">Lecture</p>
                <p class="mt-3 text-sm text-slate-300">Introduce strategic concepts with concise frameworks and visual anchors.</p>
              </div>
              <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
                <p class="text-xs uppercase tracking-[0.24em] text-cyan-200">Workshop</p>
                <p class="mt-3 text-sm text-slate-300">Turn theory into scenarios, small-group analysis, and guided critique.</p>
              </div>
              <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
                <p class="text-xs uppercase tracking-[0.24em] text-amber-200">Applied task</p>
                <p class="mt-3 text-sm text-slate-300">Use downloadable material and blog insights to create a hands-on follow-up.</p>
              </div>
            </div>
            <div class="mt-8 flex flex-wrap gap-4">
              <a href={`/expertise/${topic.slug}`} class="rounded-full bg-brand-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-brand-400">Open topic page</a>
              <a href="#resource-explorer" class="rounded-full border border-white/15 px-6 py-3 text-sm font-semibold text-slate-100 transition hover:border-white/30 hover:bg-white/5">Find matching resources</a>
            </div>
          </div>
          <aside class="grid gap-6">
            <div class="card-surface p-8">
              <p class="text-sm font-semibold uppercase tracking-[0.28em] text-brand-200">Subtopics</p>
              <ul class="mt-5 grid gap-3 text-sm text-slate-200">
                {topic.subtopics.map((item) => <li class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">{item}</li>)}
              </ul>
            </div>
            <div class="card-surface p-8">
              <p class="text-sm font-semibold uppercase tracking-[0.28em] text-brand-200">Expected learning outcomes</p>
              <ul class="mt-5 space-y-3 text-sm leading-7 text-slate-300">
                {topic.learningOutcomes.map((item) => <li>• {item}</li>)}
              </ul>
            </div>
          </aside>
        </article>
      ))}
    </div>
  </div>

  <script is:inline>
    document.querySelectorAll('[data-topic-studio]').forEach((studio) => {
      const tabs = Array.from(studio.querySelectorAll('[data-topic-tab]'));
      const panels = Array.from(studio.querySelectorAll('[data-topic-panel]'));

      const activate = (slug) => {
        tabs.forEach((tab) => {
          const active = tab.dataset.topicTab === slug;
          tab.setAttribute('aria-pressed', String(active));
          tab.classList.toggle('bg-white', active);
          tab.classList.toggle('text-slate-950', active);
          tab.classList.toggle('border', !active);
          tab.classList.toggle('border-white/10', !active);
          tab.classList.toggle('bg-white/5', !active);
          tab.classList.toggle('text-slate-100', !active);
        });
        panels.forEach((panel) => {
          const active = panel.dataset.topicPanel === slug;
          panel.classList.toggle('hidden', !active);
          panel.classList.toggle('grid', active);
        });
      };

      tabs.forEach((tab) => tab.addEventListener('click', () => activate(tab.dataset.topicTab)));
    });
  </script>
</section>
