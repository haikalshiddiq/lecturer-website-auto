---
import type { HTMLAttributes } from 'astro/types';

type Variant = 'primary' | 'secondary' | 'brand';

type Props = HTMLAttributes<'a'> & {
  href: string;
  variant?: Variant;
};

const { href, variant = 'primary', class: className = '', ...attrs } = Astro.props;

const variantClasses: Record<Variant, string> = {
  primary: 'bg-white text-slate-950 hover:bg-slate-100',
  secondary: 'border border-white/15 text-slate-100 hover:border-white/30 hover:bg-white/5',
  brand: 'bg-brand-500 text-white hover:bg-brand-400'
};
---
<a
  href={href}
  class:list={[
    'inline-flex rounded-full px-6 py-3 text-sm font-semibold transition hover:-translate-y-0.5',
    variantClasses[variant],
    className
  ]}
  {...attrs}
>
  <slot />
</a>
