---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found | Haikal Shiddiq S.Kom., M.T." description="The page you requested could not be found.">
  <section class="py-32">
    <div class="container-shell max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-brand-200">404</p>
      <h1 class="mt-6 text-5xl font-semibold text-white">This page is not available.</h1>
      <p class="mt-6 text-base leading-7 text-slate-300">Return to the homepage to continue exploring the lecturer profile, expertise areas, and learning resources.</p>
      <a href="/" class="mt-10 inline-flex rounded-full bg-brand-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-brand-400">Back to Home</a>
    </div>
  </section>
</BaseLayout>
