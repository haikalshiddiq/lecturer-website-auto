---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/sections/CTASection.astro';
import { profile } from '../data/profile';

const focusModes = [
  {
    slug: 'teaching-dna',
    label: 'Teaching DNA',
    title: 'A lecturer identity designed to connect systems thinking and practical learning.',
    description:
      'This profile is positioned as an active learning guide: translating strategic concepts into structured classroom experiences, practical exercises, and modern academic communication.',
    bullets: [
      'Theory is framed through systems, use cases, and decision-making context.',
      'Learning materials are built to move from explanation into application.',
      'Students are guided with a clear sequence: concept, workshop, reflection, and outcome.'
    ]
  },
  {
    slug: 'research-energy',
    label: 'Research energy',
    title: 'Research direction sits at the intersection of digital systems, networks, and intelligent tools.',
    description:
      'The website structure keeps the lecturer profile ready for growth into a richer academic hub: publications, applied case studies, and resource-backed topic pages that feel alive instead of archival.',
    bullets: [
      'Information systems are treated as strategic learning infrastructure.',
      'Communication protocols are translated into real-world technological literacy.',
      'Artificial intelligence is framed as an applied, responsible capability for modern learners.'
    ]
  },
  {
    slug: 'collaboration-mode',
    label: 'Collaboration mode',
    title: 'The profile is built to invite academic partnerships, guest sessions, and practical knowledge exchange.',
    description:
      'Instead of a passive CV page, this experience is designed to show how collaboration can happen: through workshops, materials, research conversations, and curriculum-oriented initiatives.',
    bullets: [
      'Clear topic pathways make it easier for institutions to identify fit.',
      'Downloadable materials demonstrate teaching direction without heavy onboarding.',
      'The contact journey is ready for inquiries about lectures, events, and applied projects.'
    ]
  }
];
---
<BaseLayout title="About | Haikal Shiddiq S.Kom., M.T." description="Academic profile, teaching philosophy, and professional positioning for Haikal Shiddiq S.Kom., M.T.">
  <section class="py-24" data-profile-studio>
    <div class="container-shell grid gap-8 lg:grid-cols-[1.05fr_0.95fr]">
      <div class="card-surface overflow-hidden p-8 sm:p-10">
        <div class="flex flex-wrap items-center gap-3 text-xs uppercase tracking-[0.3em] text-slate-400">
          <span>High-profile lecturer page</span>
          <span>•</span>
          <span>Wayground-inspired energy</span>
        </div>
        <h1 class="mt-5 text-4xl font-semibold tracking-tight text-white sm:text-5xl">A lecturer profile that feels guided, modern, and ready for serious academic trust.</h1>
        <p class="mt-5 max-w-2xl text-base leading-8 text-slate-300">{profile.longBio}</p>

        <div class="mt-8 flex flex-wrap gap-3">
          {focusModes.map((mode, index) => (
            <button
              type="button"
              data-profile-tab={mode.slug}
              aria-pressed={index === 0 ? 'true' : 'false'}
              class={`rounded-full px-5 py-3 text-sm font-semibold transition ${index === 0 ? 'bg-white text-slate-950' : 'border border-white/10 bg-white/5 text-slate-100 hover:border-white/20 hover:bg-white/10'}`}
            >
              {mode.label}
            </button>
          ))}
        </div>

        <div class="mt-8">
          {focusModes.map((mode, index) => (
            <article data-profile-panel={mode.slug} class={`${index === 0 ? 'block' : 'hidden'}`}>
              <div class="rounded-[2rem] border border-white/10 bg-white/5 p-6 sm:p-7">
                <h2 class="text-2xl font-semibold text-white">{mode.title}</h2>
                <p class="mt-4 text-sm leading-7 text-slate-300">{mode.description}</p>
                <ul class="mt-6 grid gap-3 text-sm text-slate-200">
                  {mode.bullets.map((item) => <li class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">{item}</li>)}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="grid gap-6">
        <div class="card-surface p-8">
          <p class="text-sm font-semibold uppercase tracking-[0.28em] text-brand-200">Teaching philosophy</p>
          <h2 class="mt-4 text-2xl font-semibold text-white">Learning should move from framework to implementation.</h2>
          <p class="mt-4 text-sm leading-7 text-slate-300">{profile.teachingPhilosophy}</p>
          <div class="mt-6 grid gap-3 text-sm text-slate-200">
            <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">Conceptual clarity before tools, so learners understand why systems matter.</div>
            <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">Applied tasks and scenarios so theories become decision-ready knowledge.</div>
            <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">Structured reflection so students can connect technology with management context.</div>
          </div>
        </div>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2">
          <div class="card-surface p-8">
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-brand-200">Education</p>
            <ul class="mt-5 space-y-3 text-sm leading-7 text-slate-300">
              {profile.education.map((item) => <li>• {item}</li>)}
            </ul>
          </div>
          <div class="card-surface p-8">
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-brand-200">Experience</p>
            <ul class="mt-5 space-y-3 text-sm leading-7 text-slate-300">
              {profile.experience.map((item) => <li>• {item}</li>)}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="container-shell grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
      <div class="card-surface p-8 sm:p-10">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-brand-200">Academic focus</p>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-4xl">Three pillars shape the learning and research posture of this lecturer website.</h2>
        <p class="mt-4 text-base leading-8 text-slate-300">These themes are not displayed as static labels. They are the engine for topic pages, learning resources, classroom assets, and future verified publications.</p>
        <div class="mt-8 grid gap-4 sm:grid-cols-3">
          {profile.researchInterests.slice(0, 3).map((item) => (
            <div class="rounded-[1.75rem] border border-white/10 bg-white/5 p-5">
              <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Core pillar</p>
              <p class="mt-3 text-base font-semibold text-white">{item}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="grid gap-6">
        <div class="card-surface p-8">
          <p class="text-sm font-semibold uppercase tracking-[0.28em] text-brand-200">Research interests</p>
          <ul class="mt-5 grid gap-3 text-sm text-slate-200">
            {profile.researchInterests.map((item) => <li class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">{item}</li>)}
          </ul>
        </div>
        <div class="card-surface p-8">
          <p class="text-sm font-semibold uppercase tracking-[0.28em] text-brand-200">Achievements</p>
          <ul class="mt-5 space-y-3 text-sm leading-7 text-slate-300">
            {profile.achievements.map((item) => <li>• {item}</li>)}
          </ul>
          <p class="mt-5 text-sm text-slate-400">Verified awards, certifications, talks, and publication milestones can be added without rebuilding the site structure.</p>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="Ready to replace placeholders with the full verified lecturer profile?"
    description="Send education history, experience timeline, achievements, and publication details, and I will transform this strong profile shell into a complete academic authority page."
    primaryHref="/contact"
    primaryLabel="Update Profile Details"
    secondaryHref="/publications"
    secondaryLabel="View Publications"
  />

  <script is:inline>
    document.querySelectorAll('[data-profile-studio]').forEach((studio) => {
      const tabs = Array.from(studio.querySelectorAll('[data-profile-tab]'));
      const panels = Array.from(studio.querySelectorAll('[data-profile-panel]'));

      const activate = (slug) => {
        tabs.forEach((tab) => {
          const active = tab.dataset.profileTab === slug;
          tab.setAttribute('aria-pressed', String(active));
          tab.classList.toggle('bg-white', active);
          tab.classList.toggle('text-slate-950', active);
          tab.classList.toggle('border', !active);
          tab.classList.toggle('border-white/10', !active);
          tab.classList.toggle('bg-white/5', !active);
          tab.classList.toggle('text-slate-100', !active);
        });
        panels.forEach((panel) => {
          panel.classList.toggle('hidden', panel.dataset.profilePanel !== slug);
        });
      };

      tabs.forEach((tab) => tab.addEventListener('click', () => activate(tab.dataset.profileTab)));
    });
  </script>
</BaseLayout>
