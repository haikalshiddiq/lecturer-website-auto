---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/site';

const inquiryPresets = [
  {
    slug: 'guest-lecture',
    label: 'Guest lecture',
    prompt: 'Hello, I would like to invite you for a guest lecture related to Information System Management / Communication Protocol / Artificial Intelligence. Here are the event details:'
  },
  {
    slug: 'research-collab',
    label: 'Research collaboration',
    prompt: 'Hello, I would like to discuss a potential research or academic collaboration. Here is the context, scope, and expected outcome:'
  },
  {
    slug: 'training-workshop',
    label: 'Training workshop',
    prompt: 'Hello, I would like to explore a workshop or training session for students, lecturers, or professionals. The audience and learning objectives are:'
  }
];
---
<BaseLayout title="Contact | Haikal Shiddiq S.Kom., M.T." description="Contact and collaboration page for Haikal Shiddiq S.Kom., M.T.">
  <section class="py-24" data-contact-studio>
    <div class="container-shell grid gap-8 lg:grid-cols-[0.92fr_1.08fr]">
      <div class="grid gap-6">
        <div class="card-surface p-8 sm:p-10">
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-brand-200">Collaboration desk</p>
          <h1 class="mt-4 text-4xl font-semibold tracking-tight text-white sm:text-5xl">Invite collaboration, teaching, research, or a practical learning session.</h1>
          <p class="mt-5 text-base leading-8 text-slate-300">This page is designed to make outreach feel easier and more guided. Choose an inquiry type, use the prompt starter, and send the collaboration context through the Cloudflare Worker-backed form with webhook and email-ready forwarding.</p>
          <div class="mt-8 space-y-3 text-sm text-slate-300">
            <p><span class="font-semibold text-white">Email:</span> {siteConfig.email}</p>
            <p><span class="font-semibold text-white">LinkedIn:</span> <a class="text-brand-200" href="https://www.linkedin.com/in/hicall/" target="_blank" rel="noreferrer">linkedin.com/in/hicall</a></p>
            <p><span class="font-semibold text-white">GitHub:</span> <a class="text-brand-200" href="https://github.com/haikalshiddiq" target="_blank" rel="noreferrer">github.com/haikalshiddiq</a></p>
          </div>
        </div>

        <div class="card-surface p-8">
          <p class="text-sm font-semibold uppercase tracking-[0.28em] text-brand-200">Choose a starting path</p>
          <div class="mt-5 flex flex-wrap gap-3">
            {inquiryPresets.map((preset) => (
              <button type="button" data-inquiry-preset={preset.prompt} class="rounded-full border border-white/10 bg-white/5 px-5 py-3 text-sm font-semibold text-slate-100 transition hover:border-white/20 hover:bg-white/10">
                {preset.label}
              </button>
            ))}
          </div>
          <div class="mt-6 grid gap-3 text-sm text-slate-200">
            <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">Guest lecture inquiries can align directly to the three expertise pillars.</div>
            <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">Research collaboration requests can describe scope, timeline, and expected outputs.</div>
            <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">Training requests can specify the target audience, duration, and desired learning outcomes.</div>
          </div>
        </div>
      </div>

      <div class="card-surface p-8 sm:p-10">
        <div class="mb-6 flex flex-wrap items-start justify-between gap-4">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-brand-200">Inquiry form</p>
            <h2 class="mt-3 text-2xl font-semibold text-white">Send a structured inquiry</h2>
          </div>
          <span class="rounded-full border border-emerald-400/20 bg-emerald-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-emerald-200">Worker-forwarded</span>
        </div>
        <form action="https://lecturer-materials.hicall.workers.dev/api/contact" method="post" class="grid gap-5" data-contact-form>
          <input type="hidden" name="subject" value="Lecturer website inquiry" />
          <input type="hidden" name="source" value="lecturer-materials-contact-page" />
          <input type="hidden" name="formLoadedAt" value="" data-form-loaded-at />
          <div class="hidden" aria-hidden="true">
            <label for="website">Leave this field empty</label>
            <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
          </div>
          <div class="grid gap-5 md:grid-cols-2">
            <div>
              <label class="mb-2 block text-sm font-medium text-white" for="name">Name</label>
              <input class="w-full rounded-2xl border-white/10 bg-white/5 text-white placeholder:text-slate-500" id="name" name="name" type="text" placeholder="Your name" required minlength="2" maxlength="120" />
            </div>
            <div>
              <label class="mb-2 block text-sm font-medium text-white" for="email">Email</label>
              <input class="w-full rounded-2xl border-white/10 bg-white/5 text-white placeholder:text-slate-500" id="email" name="email" type="email" placeholder="you@example.com" required maxlength="160" />
            </div>
          </div>
          <div>
            <label class="mb-2 block text-sm font-medium text-white" for="message">Message</label>
            <textarea class="min-h-48 w-full rounded-2xl border-white/10 bg-white/5 text-white placeholder:text-slate-500" id="message" name="message" placeholder="Tell me about the collaboration, event, workshop, or learning need." required minlength="20" maxlength="3000"></textarea>
          </div>
          <div class="grid gap-4 rounded-[1.75rem] border border-white/10 bg-white/5 p-5 text-sm text-slate-300 sm:grid-cols-3">
            <div>
              <p class="font-semibold text-white">1. Context</p>
              <p class="mt-2">Describe institution, audience, or research environment.</p>
            </div>
            <div>
              <p class="font-semibold text-white">2. Goal</p>
              <p class="mt-2">Explain the intended learning outcome or collaboration result.</p>
            </div>
            <div>
              <p class="font-semibold text-white">3. Timeline</p>
              <p class="mt-2">Share the preferred date, duration, or project window.</p>
            </div>
          </div>
          <p class="text-xs leading-6 text-slate-400">This form uses lightweight anti-spam checks such as a hidden trap field, timing validation, and content screening.</p>
          <div data-contact-form-status class="hidden rounded-2xl border px-4 py-3 text-sm"></div>
          <button type="submit" class="rounded-full bg-brand-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-brand-400 disabled:cursor-not-allowed disabled:opacity-70" data-contact-submit>Send inquiry</button>
        </form>
      </div>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('[data-contact-studio]').forEach((section) => {
      const textarea = section.querySelector('#message');
      const form = section.querySelector('[data-contact-form]');
      const statusBox = section.querySelector('[data-contact-form-status]');
      const submitButton = section.querySelector('[data-contact-submit]');
      const loadedAtField = section.querySelector('[data-form-loaded-at]');
      const honeypotField = section.querySelector('#website');

      if (loadedAtField) {
        loadedAtField.value = String(Date.now());
      }

      section.querySelectorAll('[data-inquiry-preset]').forEach((button) => {
        button.addEventListener('click', () => {
          if (!textarea) return;
          const prompt = button.dataset.inquiryPreset ?? '';
          textarea.value = prompt;
          textarea.focus();
          textarea.setSelectionRange(textarea.value.length, textarea.value.length);
        });
      });

      if (!form || !statusBox || !submitButton) return;

      const setStatus = (kind, message) => {
        statusBox.classList.remove('hidden', 'border-emerald-400/30', 'bg-emerald-400/10', 'text-emerald-100', 'border-rose-400/30', 'bg-rose-400/10', 'text-rose-100');

        if (kind === 'success') {
          statusBox.classList.add('border-emerald-400/30', 'bg-emerald-400/10', 'text-emerald-100');
        } else {
          statusBox.classList.add('border-rose-400/30', 'bg-rose-400/10', 'text-rose-100');
        }

        statusBox.textContent = message;
      };

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        if (honeypotField?.value) {
          setStatus('error', 'Submission blocked by anti-spam protection.');
          return;
        }

        const now = Date.now();
        const loadedAt = Number(loadedAtField?.value || 0);
        if (loadedAt && now - loadedAt < 2500) {
          setStatus('error', 'Please take a moment to complete the form before sending.');
          return;
        }

        submitButton.setAttribute('disabled', 'disabled');
        submitButton.textContent = 'Sending…';
        statusBox.classList.add('hidden');

        try {
          const response = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: {
              Accept: 'application/json'
            }
          });

          const payload = await response.json().catch(() => ({}));

          if (!response.ok || !payload.ok) {
            throw new Error(payload.error || payload.detail || 'Unable to send the inquiry right now.');
          }

          setStatus('success', payload.message || 'Inquiry sent successfully.');
          form.reset();
          if (loadedAtField) {
            loadedAtField.value = String(Date.now());
          }
        } catch (error) {
          setStatus('error', error instanceof Error ? error.message : 'Unable to send the inquiry right now.');
        } finally {
          submitButton.removeAttribute('disabled');
          submitButton.textContent = 'Send inquiry';
        }
      });
    });
  </script>
</BaseLayout>
