---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PublicationCard from '../../components/cards/PublicationCard.astro';

const publications = (await getCollection('publications')).sort((a, b) => b.data.year - a.data.year);
const featured = publications[0];
const typeFilters = ['All', ...new Set(publications.map((item) => item.data.type))];
---
<BaseLayout title="Publications | Haikal Shiddiq S.Kom., M.T." description="Research, publications, projects, and academic initiatives.">
  <section class="py-24" data-publication-hub>
    <div class="container-shell">
      <div class="grid gap-8 lg:grid-cols-[1.02fr_0.98fr]">
        <div class="card-surface p-8 sm:p-10">
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-brand-200">Publications & projects</p>
          <h1 class="mt-4 text-4xl font-semibold tracking-tight text-white sm:text-5xl">A more guided showcase for research outputs, learning initiatives, and technical work.</h1>
          <p class="mt-5 max-w-2xl text-base leading-8 text-slate-300">This page now behaves more like a curated academic gallery. Visitors can filter by output type and quickly understand where each project sits within the broader lecturer profile.</p>
          <div class="mt-8 flex flex-wrap gap-3">
            {typeFilters.map((filter, index) => (
              <button
                type="button"
                data-publication-filter={filter}
                aria-pressed={index === 0 ? 'true' : 'false'}
                class={`rounded-full px-5 py-3 text-sm font-semibold transition ${index === 0 ? 'bg-white text-slate-950' : 'border border-white/10 bg-white/5 text-slate-100 hover:border-white/20 hover:bg-white/10'}`}
              >
                {filter}
              </button>
            ))}
          </div>
        </div>

        {featured && (
          <div class="card-surface p-8 sm:p-10">
            <div class="flex items-center justify-between gap-3 text-xs uppercase tracking-[0.24em] text-slate-400">
              <span>Spotlight</span>
              <span>{featured.data.year}</span>
            </div>
            <h2 class="mt-4 text-3xl font-semibold text-white">{featured.data.title}</h2>
            <p class="mt-4 text-sm leading-7 text-slate-300">{featured.data.summary}</p>
            <div class="mt-6 flex flex-wrap gap-2">
              {featured.data.tags.map((tag) => <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-slate-200">{tag}</span>)}
            </div>
            <div class="mt-8 flex flex-wrap gap-4">
              {featured.data.externalUrl && <a href={featured.data.externalUrl} class="rounded-full bg-brand-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-brand-400" target="_blank" rel="noreferrer">Open featured item</a>}
              <a href="/about" class="rounded-full border border-white/15 px-6 py-3 text-sm font-semibold text-slate-100 transition hover:border-white/30 hover:bg-white/5">View lecturer profile</a>
            </div>
          </div>
        )}
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-2">
        {publications.map((item) => (
          <div data-publication-card={item.data.type}>
            <PublicationCard
              title={item.data.title}
              year={item.data.year}
              type={item.data.type}
              summary={item.data.summary}
              status={item.data.status}
              href={item.data.externalUrl}
              tags={item.data.tags}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('[data-publication-hub]').forEach((hub) => {
      const buttons = Array.from(hub.querySelectorAll('[data-publication-filter]'));
      const cards = Array.from(hub.querySelectorAll('[data-publication-card]'));
      const applyFilter = (value) => {
        buttons.forEach((button) => {
          const active = button.dataset.publicationFilter === value;
          button.setAttribute('aria-pressed', String(active));
          button.classList.toggle('bg-white', active);
          button.classList.toggle('text-slate-950', active);
          button.classList.toggle('border', !active);
          button.classList.toggle('border-white/10', !active);
          button.classList.toggle('bg-white/5', !active);
          button.classList.toggle('text-slate-100', !active);
        });
        cards.forEach((card) => {
          const visible = value === 'All' || card.dataset.publicationCard === value;
          card.classList.toggle('hidden', !visible);
        });
      };
      buttons.forEach((button) => button.addEventListener('click', () => applyFilter(button.dataset.publicationFilter)));
    });
  </script>
</BaseLayout>
