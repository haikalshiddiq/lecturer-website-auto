---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ResourceExplorer from '../../components/sections/ResourceExplorer.astro';
const resources = (await getCollection('resources'))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .map((resource) => ({
    ...resource.data,
    slug: resource.id.replace(/\.md$/, '')
  }));
---
<BaseLayout title="Resources | Haikal Shiddiq S.Kom., M.T." description="Interactive learning resources, downloadable kits, modules, and articles for students and professional learners.">
  <ResourceExplorer
    resources={resources}
    title="An interactive library for lecture materials, curated notes, and downloadable class assets"
    description="Browse by topic just like a modern learning platform: filter the catalog, open the reading page, or download the resource that fits the lesson plan."
  />
</BaseLayout>
